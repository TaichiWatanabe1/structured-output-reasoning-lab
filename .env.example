# Azure OpenAI credentials (machine-specific, not committed)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# 実行順ランダム化シード (省略時 42)
EXEC_SEED=42

# Optional: HuggingFace datasets cache (default: ./data/hf_cache)
HF_DATASETS_CACHE=./data/hf_cache

# 軸5 (Model: key / deployment / reasoning_effort) は conditions.yaml の
# `models:` セクションで宣言する (旧 AZURE_OPENAI_DEPLOYMENT_NAME_*,
# AZURE_OPENAI_REASONING_EFFORT は廃止)。

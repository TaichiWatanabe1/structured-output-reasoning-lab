# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# 軸5 (Model): 3 デプロイメント名を Azure ポータルから取得して埋める。
# 少なくとも 1 つ設定されていれば実行可能 (未設定モデルは自動スキップ)。
AZURE_OPENAI_DEPLOYMENT_NAME_GPT41=
AZURE_OPENAI_DEPLOYMENT_NAME_GPT41_MINI=
AZURE_OPENAI_DEPLOYMENT_NAME_GPT5=

# gpt-5 系のみに適用される reasoning_effort (minimal / low / medium / high)
# 本実験は minimal 固定で hidden CoT トークン爆発を抑える前提
AZURE_OPENAI_REASONING_EFFORT=minimal

# 実行順ランダム化シード (省略時 42)
EXEC_SEED=42

# Optional: HuggingFace datasets cache (default: ./data/hf_cache)
HF_DATASETS_CACHE=./data/hf_cache
